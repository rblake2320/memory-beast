rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: memories
    // Document ID: auto-generated
    // Fields:
    //   - content: string (required, < 5000 chars)
    //   - embedding: list (optional, numbers)
    //   - valid_from: timestamp (required)
    //   - valid_until: timestamp (optional)
    //   - transaction_time: timestamp (required)
    //   - source_id: string (optional)
    //   - confidence: number (required, 0.0 to 1.0)
    //   - derivation_tier: int (required, 0-4)
    //   - prev_hash: string (optional)
    //   - hash: string (required, 64 chars)
    //   - superseded_by: string (optional)
    //   - uid: string (required, matches owner)
    //
    // Collection: sources
    // Document ID: auto-generated
    // Fields:
    //   - type: string (required, enum)
    //   - metadata: map (optional)
    //   - is_invalidated: bool (optional)
    //   - uid: string (required, matches owner)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "rob47595@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidMemory(data) {
      return data.keys().hasAll(['content', 'valid_from', 'transaction_time', 'confidence', 'derivation_tier', 'uid', 'hash']) &&
             data.content is string && data.content.size() < 5000 &&
             data.valid_from is timestamp &&
             data.transaction_time is timestamp &&
             data.confidence is number && data.confidence >= 0 && data.confidence <= 1 &&
             data.derivation_tier is int && data.derivation_tier >= 0 && data.derivation_tier <= 4 &&
             data.hash is string && data.hash.size() == 64 &&
             (!('prev_hash' in data) || data.prev_hash == null || (data.prev_hash is string && data.prev_hash.size() == 64)) &&
             (!('source_id' in data) || data.source_id == null || data.source_id is string) &&
             (!('superseded_by' in data) || data.superseded_by is string);
    }

    function isValidSource(data) {
      return data.keys().hasAll(['type', 'uid']) &&
             data.type in ['document', 'chat', 'web', 'user_input'] &&
             data.uid is string;
    }

    // Rules
    match /memories/{memoryId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidMemory(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidMemory(request.resource.data) && uidNotModified();
      allow delete: if (isDocOwner() || isAdmin());
    }

    match /sources/{sourceId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidSource(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidSource(request.resource.data) && uidNotModified();
      allow delete: if (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }
  }
}
