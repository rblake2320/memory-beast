# ── Database ─────────────────────────────────────────────────────────────────
MW_DATABASE_URL=postgresql://memoryweb:memoryweb@localhost:5432/memoryweb
MW_DB_SCHEMA=memoryweb

# ── Redis / Celery ───────────────────────────────────────────────────────────
MW_REDIS_URL=redis://localhost:6379/1
MW_CELERY_BROKER_URL=redis://localhost:6379/1
MW_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Ollama ───────────────────────────────────────────────────────────────────
MW_OLLAMA_BASE_URL=http://localhost:11434
MW_OLLAMA_MODEL=llama3.2:3b

# ── Embeddings ───────────────────────────────────────────────────────────────
MW_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
MW_EMBED_DIM=384

# ── Server ───────────────────────────────────────────────────────────────────
MW_PORT=8100

# ── Security (optional — empty = no auth in dev mode) ────────────────────────
MW_API_KEY=
MW_CORS_ORIGINS=*

# ── Auth (optional — set to true for multi-user SaaS) ────────────────────────
MW_AUTH_ENABLED=false
MW_JWT_SECRET=change-me-use-256-bit-random-secret
MW_JWT_ALGORITHM=HS256
MW_JWT_EXPIRY_HOURS=24

# ── Pro License (optional — empty = community/owner mode) ────────────────────
MW_LICENSE_KEY=
MW_LICENSE_SERVER=https://license.memorybeast.app

# ── MINJA Poisoning Defense (optional LLM validation layer) ──────────────────
MW_POISON_LLM_ENABLED=false
MW_POISON_LLM_MODEL=llama3.1:8b
MW_POISON_LLM_TIMEOUT=5.0
MW_POISON_LLM_MIN_SCORE=0.2
